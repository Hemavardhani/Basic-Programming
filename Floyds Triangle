package Patterns;

public class Floyds {

    public static void main(String args[])
    {
        int i,j,k=1,n=5;

        for(i=0;i<n;i++)
        {
            for(j=0;j<=i;j++)
            {
                System.out.print(k+" ");
                k++;
            }
            System.out.println();
        }
    }
    
}
